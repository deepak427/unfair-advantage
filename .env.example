# ============================================================
# GOOGLE CLOUD
# ============================================================
GCP_PROJECT_ID=your-gcp-project-id
GCP_REGION=us-central1
GCS_BUCKET_NAME=your-bucket-name

# ============================================================
# VERTEX AI
# ============================================================
VERTEX_AI_RAG_CORPUS_NAME=books-rag-corpus
VERTEX_AI_EMBEDDING_MODEL=text-embedding-004
VERTEX_AI_LOCATION=us-central1

# ============================================================
# GEMINI MODELS
# ============================================================
GEMINI_MODEL_ROOT=gemini-2.5-flash
GEMINI_MODEL_REASONING=gemini-2.5-pro
GEMINI_MODEL_INGESTION=gemini-2.0-flash

# ============================================================
# NEO4J / GRAPHITI
# ============================================================
NEO4J_URI=neo4j+s://xxxxxxxx.databases.neo4j.io
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=your-neo4j-password
NEO4J_DATABASE=neo4j

# ============================================================
# INGESTION SETTINGS
# ============================================================
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
MAX_CHUNKS_PER_BATCH=50

# ============================================================
# AGENT SETTINGS
# ============================================================
MAX_RAG_RESULTS=10
MAX_GRAPH_RESULTS=10
APP_PORT=8080
APP_ENV=development
LOG_LEVEL=INFO
